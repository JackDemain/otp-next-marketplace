# ============================================================================
# OTP NEXT — Environment variables (MVP0)
# Copy to .env and fill values. NEVER commit .env to git.
# ============================================================================

# PostgreSQL
POSTGRES_DB=otp_next
POSTGRES_USER=otp_next
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Spring Boot
SERVER_PORT=3000
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/otp_next
SPRING_DATASOURCE_USERNAME=otp_next
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT — MUST be at least 32 characters
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_SECRET_KEY_HERE_1234567890

# Hardcoded auth (MVP0 demo — no registration)
APP_AUTH_LOGIN=otp
APP_AUTH_PASSWORD=otp123

# CORS (demo — open)
CORS_ALLOWED_ORIGINS=*
